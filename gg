<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Nexora Technologies — Pakistan's leading AI-powered digital marketing agency. Website, Social Media, AI Chatbots, Ads from Karachi.">
<meta name="keywords" content="digital marketing agency karachi, social media management pakistan, website development, AI chatbot, SEO Pakistan, Nexora Technologies">
<meta property="og:title" content="Nexora Technologies — AI-Powered Digital Agency">
<meta property="og:description" content="Transform your business into a digital empire. AI-powered marketing services from Karachi.">
<title>Nexora Technologies — AI-Powered Digital Agency</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
:root{
  --dark:#0A0008;
  --dark2:#0D000F;
  --dark3:#130018;
  --card:#1A0025;
  --card2:#1F0030;
  --purple:#7C3AED;
  --purple2:#9F67FF;
  --purple3:#6D28D9;
  --gold:#F59E0B;
  --gold2:#FCD34D;
  --gold3:#D97706;
  --white:#FFFFFF;
  --text:#EDE9FE;
  --muted:#A78BCA;
  --muted2:#6B5A8A;
  --border:rgba(124,58,237,0.2);
  --border2:rgba(124,58,237,0.4);
  --glow:rgba(124,58,237,0.15);
}
body{background:var(--dark);color:var(--text);font-family:'DM Sans',sans-serif;line-height:1.6;overflow-x:hidden}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--dark)}
::-webkit-scrollbar-thumb{background:var(--purple);border-radius:3px}

/* PARTICLES */
#particles{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.particle{position:absolute;border-radius:50%;animation:float-p linear infinite;opacity:0}
@keyframes float-p{0%{transform:translateY(100vh) scale(0);opacity:0}10%{opacity:1}90%{opacity:0.5}100%{transform:translateY(-100px) scale(1);opacity:0}}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:999;background:rgba(10,0,8,0.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 5%}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:66px;max-width:1200px;margin:0 auto}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;text-decoration:none;color:var(--white)}
.logo span{color:var(--gold);text-shadow:0 0 20px rgba(245,158,11,0.5)}
.nav-links{display:flex;align-items:center;gap:26px;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:14px;font-weight:500;transition:all .2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--gold);transition:width .3s}
.nav-links a:hover{color:var(--gold)}
.nav-links a:hover::after{width:100%}
.nav-cta{background:linear-gradient(135deg,var(--purple),var(--purple3))!important;color:var(--white)!important;padding:8px 22px;border-radius:8px;font-weight:700!important;box-shadow:0 4px 15px rgba(124,58,237,0.3)}
.nav-cta:hover{transform:translateY(-2px)!important;box-shadow:0 6px 20px rgba(124,58,237,0.5)!important}
.nav-cta::after{display:none!important}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
.hamburger span{width:24px;height:2px;background:var(--text);border-radius:2px;transition:all .3s;display:block}
.mob-menu{display:none;position:fixed;top:66px;left:0;right:0;background:var(--dark2);border-bottom:1px solid var(--border);padding:20px 5%;z-index:998}
.mob-menu.open{display:block}
.mob-menu a{display:block;padding:12px 0;color:var(--text);text-decoration:none;font-size:15px;border-bottom:1px solid var(--border)}

/* SECTIONS */
section{padding:90px 5%;position:relative;z-index:1}
.container{max-width:1200px;margin:0 auto}
.sec-label{font-size:11px;font-weight:700;color:var(--gold);letter-spacing:3px;text-transform:uppercase;margin-bottom:12px}
.sec-title{font-family:'Syne',sans-serif;font-size:clamp(28px,4vw,46px);font-weight:800;color:var(--white);margin-bottom:16px;line-height:1.12}
.sec-title span{color:var(--gold)}
.sec-sub{font-size:16px;color:var(--muted);max-width:560px;line-height:1.75}
.sec-head{margin-bottom:52px}
.sec-head.center{text-align:center}
.sec-head.center .sec-sub{margin:0 auto}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:8px;padding:13px 30px;border-radius:10px;font-weight:700;font-size:15px;text-decoration:none;transition:all .25s;cursor:pointer;border:none;font-family:'Syne',sans-serif}
.btn-primary{background:linear-gradient(135deg,var(--purple),var(--purple3));color:var(--white);box-shadow:0 4px 20px rgba(124,58,237,0.35)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(124,58,237,0.5)}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold3));color:var(--dark);box-shadow:0 4px 20px rgba(245,158,11,0.3)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(245,158,11,0.45)}
.btn-outline{background:transparent;color:var(--text);border:1px solid var(--border2)}
.btn-outline:hover{border-color:var(--gold);color:var(--gold)}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;padding-top:110px;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 70% 30%,rgba(124,58,237,0.12) 0%,transparent 60%),radial-gradient(ellipse at 20% 80%,rgba(245,158,11,0.07) 0%,transparent 50%)}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;max-width:1200px;margin:0 auto;width:100%}
.hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(124,58,237,0.12);border:1px solid rgba(124,58,237,0.3);padding:7px 18px;border-radius:100px;font-size:13px;color:var(--purple2);margin-bottom:24px;font-weight:500}
.tag-pulse{width:7px;height:7px;border-radius:50%;background:var(--gold);animation:pulse 2s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(245,158,11,0.4)}50%{opacity:0.6;box-shadow:0 0 0 6px rgba(245,158,11,0)}}
h1{font-family:'Syne',sans-serif;font-size:clamp(36px,5vw,66px);font-weight:800;line-height:1.06;margin-bottom:22px;color:var(--white)}
h1 em{font-style:normal;color:var(--gold);text-shadow:0 0 30px rgba(245,158,11,0.3)}
.hero-sub{font-size:17px;color:var(--muted);margin-bottom:36px;line-height:1.8;max-width:490px}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:44px}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.stat{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px;text-align:center;transition:all .3s}
.stat:hover{border-color:var(--gold);transform:translateY(-3px)}
.stat-num{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;color:var(--gold);text-shadow:0 0 20px rgba(245,158,11,0.3)}
.stat-lbl{font-size:12px;color:var(--muted);margin-top:3px}
/* HERO VISUAL */
.hero-visual{position:relative}
.hv-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:28px;animation:float-card 4s ease-in-out infinite}
@keyframes float-card{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.hv-head{display:flex;align-items:center;gap:8px;margin-bottom:22px}
.hv-dot{width:10px;height:10px;border-radius:50%}
.hv-dot.r{background:#e55353}.hv-dot.y{background:var(--gold)}.hv-dot.g{background:#1FD28C}
.hv-ttl{font-size:12px;color:var(--muted);margin-left:6px}
.metric{margin-bottom:16px}
.m-top{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:6px}
.m-top span:last-child{color:var(--gold);font-weight:600}
.m-bar{height:8px;background:rgba(255,255,255,0.05);border-radius:100px;overflow:hidden}
.m-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,var(--purple),var(--gold));animation:bar-grow 1.5s ease forwards}
@keyframes bar-grow{from{width:0}to{width:var(--w)}}
.fb{position:absolute;background:var(--card2);border:1px solid var(--border2);border-radius:12px;padding:9px 16px;font-size:12px;font-weight:600;animation:float-card 3s ease-in-out infinite}
.fb1{top:-18px;right:-18px;color:var(--gold);animation-delay:.5s}
.fb2{bottom:-14px;left:-14px;color:var(--purple2);animation-delay:1s}

/* SERVICES */
#services{background:var(--dark2)}
.svc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px}
.svc-card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:30px;transition:all .3s;position:relative;overflow:hidden;cursor:default}
.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--purple),var(--gold));transform:scaleX(0);transform-origin:left;transition:transform .4s}
.svc-card::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(124,58,237,0.08),transparent 60%);opacity:0;transition:opacity .3s}
.svc-card:hover{border-color:var(--border2);transform:translateY(-5px);box-shadow:0 20px 40px rgba(124,58,237,0.15)}
.svc-card:hover::before{transform:scaleX(1)}
.svc-card:hover::after{opacity:1}
.svc-icon{width:52px;height:52px;border-radius:14px;background:rgba(124,58,237,0.15);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:20px;color:var(--purple2);transition:all .3s}
.svc-card:hover .svc-icon{background:rgba(245,158,11,0.15);border-color:rgba(245,158,11,0.3);color:var(--gold)}
.svc-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;color:var(--white);margin-bottom:10px}
.svc-desc{font-size:14px;color:var(--muted);line-height:1.7}
.svc-from{margin-top:16px;font-size:13px;color:var(--gold);font-weight:600;display:flex;align-items:center;gap:6px}
.svc-from::before{content:'';width:20px;height:1px;background:var(--gold)}

/* RATES */
#rates{background:var(--dark)}
.rate-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:30px}
.rtab{padding:8px 20px;border-radius:100px;font-size:13px;font-weight:500;cursor:pointer;border:1px solid var(--border);color:var(--muted);background:transparent;transition:all .2s;font-family:'DM Sans',sans-serif}
.rtab.active{background:linear-gradient(135deg,var(--purple),var(--purple3));color:var(--white);border-color:var(--purple);font-weight:700;box-shadow:0 4px 14px rgba(124,58,237,0.3)}
.rtab:hover:not(.active){border-color:var(--border2);color:var(--text)}
.rate-wrap{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden}
.rate-table{width:100%;border-collapse:collapse;display:none}
.rate-table.active{display:table}
.rate-table th{text-align:left;padding:14px 20px;font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:1.5px;background:rgba(124,58,237,0.08);border-bottom:1px solid var(--border)}
.rate-table td{padding:13px 20px;font-size:14px;border-bottom:1px solid rgba(124,58,237,0.07);color:var(--text);transition:background .2s}
.rate-table tr:hover td{background:rgba(124,58,237,0.05)}
.rate-table tr:last-child td{border-bottom:none}
.rate-table td:nth-child(2){color:var(--gold);font-weight:700;white-space:nowrap}
.rate-table td:nth-child(3){color:var(--muted);font-size:13px}
.rbadge{display:inline-block;font-size:10px;padding:2px 8px;border-radius:20px;margin-left:8px;vertical-align:middle;font-weight:700}
.rb-new{background:rgba(31,210,140,0.15);color:#1FD28C}
.rb-hot{background:rgba(245,158,11,0.15);color:var(--gold)}

/* PLANS */
#plans{background:var(--dark2)}
.plans-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:22px}
.plan-card{background:var(--card);border:1px solid var(--border);border-radius:22px;padding:30px;position:relative;transition:all .3s;display:flex;flex-direction:column}
.plan-card.hot{border-color:var(--purple);background:linear-gradient(145deg,var(--card),rgba(124,58,237,0.08));box-shadow:0 0 40px rgba(124,58,237,0.15)}
.plan-card:hover{transform:translateY(-6px);box-shadow:0 24px 48px rgba(124,58,237,0.2)}
.pop-badge{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--purple),var(--gold3));color:var(--white);font-size:11px;font-weight:700;padding:5px 18px;border-radius:100px;white-space:nowrap;font-family:'Syne',sans-serif;box-shadow:0 4px 14px rgba(124,58,237,0.4)}
.plan-name{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:var(--white);margin-bottom:6px}
.plan-price{font-family:'Syne',sans-serif;font-size:40px;font-weight:800;color:var(--gold);margin:12px 0 4px;line-height:1;text-shadow:0 0 20px rgba(245,158,11,0.25)}
.plan-price small{font-size:14px;color:var(--muted);font-weight:400;font-family:'DM Sans',sans-serif}
.plan-tagline{font-size:13px;color:var(--muted);padding-bottom:18px;margin-bottom:18px;border-bottom:1px solid var(--border)}
.ai-box{background:rgba(124,58,237,0.08);border:0.5px solid var(--border);border-radius:10px;padding:10px 13px;margin-bottom:18px;font-size:12px;color:var(--muted)}
.ai-box strong{color:var(--purple2);display:block;font-size:11px;margin-bottom:4px}
.plan-feats{list-style:none;flex:1;margin-bottom:24px}
.plan-feats li{padding:7px 0;font-size:13px;display:flex;align-items:flex-start;gap:9px;border-bottom:0.5px solid rgba(124,58,237,0.08);color:var(--text)}
.plan-feats li.off{color:var(--muted2)}
.feat-check{color:#1FD28C;flex-shrink:0;margin-top:2px}
.feat-x{color:var(--muted2);flex-shrink:0;margin-top:2px}
.plan-btn{display:block;text-align:center;padding:13px;border-radius:11px;font-weight:700;font-size:14px;text-decoration:none;transition:all .25s;font-family:'Syne',sans-serif;cursor:pointer;border:none;width:100%}
.plan-btn-fill{background:linear-gradient(135deg,var(--purple),var(--purple3));color:var(--white);box-shadow:0 4px 16px rgba(124,58,237,0.3)}
.plan-btn-fill:hover{box-shadow:0 8px 24px rgba(124,58,237,0.5);transform:translateY(-1px)}
.plan-btn-out{background:transparent;color:var(--purple2);border:1px solid var(--purple)}
.plan-btn-out:hover{background:rgba(124,58,237,0.1)}

/* CONTACT */
#contact{background:var(--dark)}
.form-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:start}
.form-box{background:var(--card);border:1px solid var(--border);border-radius:22px;padding:38px}
.fg{margin-bottom:18px}
.flabel{display:block;font-size:13px;font-weight:500;color:var(--muted);margin-bottom:7px}
.finput{width:100%;background:rgba(124,58,237,0.06);border:1px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--text);font-size:14px;font-family:'DM Sans',sans-serif;transition:all .2s;outline:none}
.finput:focus{border-color:var(--purple2);box-shadow:0 0 0 3px rgba(124,58,237,0.12)}
.finput option{background:var(--dark2)}
textarea.finput{resize:vertical;min-height:95px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.form-success{display:none;text-align:center;padding:24px}
.form-success .big{font-size:56px;margin-bottom:14px;animation:bounce-in .5s ease}
@keyframes bounce-in{0%{transform:scale(0)}80%{transform:scale(1.1)}100%{transform:scale(1)}}
.form-success h3{font-family:'Syne',sans-serif;font-size:22px;color:var(--white);margin-bottom:8px}
.form-success p{font-size:14px;color:var(--muted)}
.form-err{display:none;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:10px 14px;font-size:13px;color:#FCA5A5;margin-bottom:16px}
.contact-side{display:flex;flex-direction:column;gap:14px}
.ci{display:flex;align-items:flex-start;gap:14px;background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px;transition:all .3s}
.ci:hover{border-color:var(--border2);transform:translateX(4px)}
.ci-icon{width:42px;height:42px;background:rgba(124,58,237,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;color:var(--purple2)}
.ci-label{font-size:11px;color:var(--muted);margin-bottom:3px;text-transform:uppercase;letter-spacing:1px}
.ci-val{font-size:14px;color:var(--text);font-weight:500}
.pm-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px}
.pm-title{font-size:13px;font-weight:600;color:var(--white);margin-bottom:12px}
.pm-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.pm-item{background:rgba(124,58,237,0.07);border:0.5px solid var(--border);border-radius:8px;padding:9px 12px;font-size:12px;color:var(--muted);display:flex;align-items:center;gap:7px;transition:all .2s}
.pm-item:hover{border-color:var(--gold);color:var(--gold)}
.pm-dot{width:7px;height:7px;border-radius:50%;background:var(--gold);flex-shrink:0}

/* SOCIAL BUTTONS */
#social{background:var(--dark2)}
.social-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px}
.soc-btn{display:flex;align-items:center;gap:14px;padding:18px 22px;border-radius:16px;text-decoration:none;transition:all .3s;border:1px solid var(--border);font-weight:600;font-size:15px;font-family:'Syne',sans-serif;position:relative;overflow:hidden}
.soc-btn::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .3s}
.soc-btn:hover{transform:translateY(-4px);box-shadow:0 16px 32px rgba(0,0,0,0.3)}
.soc-btn:hover::before{opacity:1}
.soc-btn i{font-size:24px;z-index:1;position:relative}
.soc-btn span{z-index:1;position:relative}
.soc-tiktok{background:#010101;color:#fff;border-color:rgba(255,255,255,0.1)}
.soc-tiktok::before{background:linear-gradient(135deg,#010101,#2d2d2d)}
.soc-tiktok i{background:linear-gradient(135deg,#69C9D0,#EE1D52);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.soc-youtube{background:#1a0000;color:#fff;border-color:rgba(255,0,0,0.2)}
.soc-youtube::before{background:linear-gradient(135deg,#1a0000,#2d0000)}
.soc-youtube i{color:#FF0000}
.soc-instagram{background:#1a0a00;color:#fff;border-color:rgba(225,48,108,0.2)}
.soc-instagram::before{background:linear-gradient(135deg,#1a0a00,#2d1500)}
.soc-instagram i{background:linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.soc-x{background:#000;color:#fff;border-color:rgba(255,255,255,0.1)}
.soc-x::before{background:linear-gradient(135deg,#000,#1a1a1a)}
.soc-whatsapp{background:#001a0a;color:#fff;border-color:rgba(37,211,102,0.2)}
.soc-whatsapp::before{background:linear-gradient(135deg,#001a0a,#002d12)}
.soc-whatsapp i{color:#25D366}
.soc-facebook{background:#001030;color:#fff;border-color:rgba(24,119,242,0.2)}
.soc-facebook::before{background:linear-gradient(135deg,#001030,#001850)}
.soc-facebook i{color:#1877F2}
.soc-linkedin{background:#00101a;color:#fff;border-color:rgba(0,119,181,0.2)}
.soc-linkedin::before{background:linear-gradient(135deg,#00101a,#001a2d)}
.soc-linkedin i{color:#0077B5}

/* REVIEWS */
#reviews{background:var(--dark)}
.rev-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}
.rev-card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:26px;transition:all .3s;position:relative;overflow:hidden}
.rev-card::before{content:'❝';position:absolute;top:12px;right:20px;font-size:60px;color:rgba(124,58,237,0.1);font-family:serif}
.rev-card:hover{border-color:var(--border2);transform:translateY(-4px);box-shadow:0 16px 36px rgba(124,58,237,0.12)}
.rev-stars{color:var(--gold);font-size:15px;margin-bottom:14px;letter-spacing:2px;text-shadow:0 0 10px rgba(245,158,11,0.3)}
.rev-text{font-size:14px;color:var(--muted);line-height:1.8;margin-bottom:20px;font-style:italic}
.rev-person{display:flex;align-items:center;gap:12px}
.rev-av{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--gold3));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:15px;color:var(--white);flex-shrink:0}
.rev-name{font-size:14px;font-weight:700;color:var(--white)}
.rev-biz{font-size:12px;color:var(--muted)}

/* GALLERY */
#gallery{background:var(--dark2)}
.gal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px}
.gal-item{aspect-ratio:1;border-radius:16px;background:var(--card);border:1px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;font-size:40px;transition:all .3s;cursor:pointer;position:relative;overflow:hidden}
.gal-item::after{content:'View';position:absolute;inset:0;background:rgba(124,58,237,0.85);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:var(--white);opacity:0;transition:opacity .3s}
.gal-item:hover{border-color:var(--purple);transform:scale(1.04)}
.gal-item:hover::after{opacity:1}
.gal-label{font-size:11px;color:var(--muted);font-weight:500}

/* FREE TOOLS */
#tools{background:var(--dark)}
.tools-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:22px}
.tool-card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:26px;transition:all .3s}
.tool-card:hover{border-color:var(--border2);transform:translateY(-3px)}
.tool-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--white);margin-bottom:6px;display:flex;align-items:center;gap:10px}
.tool-tag{background:rgba(124,58,237,0.15);color:var(--purple2);font-size:10px;padding:2px 9px;border-radius:20px;font-weight:700;border:0.5px solid var(--border)}
.tool-desc{font-size:13px;color:var(--muted);margin-bottom:16px}
.tool-area{background:rgba(124,58,237,0.04);border:1px dashed var(--border);border-radius:12px;padding:20px;text-align:center;min-height:120px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px}
.tool-area input[type=file]{display:none}
.tool-area textarea,.tool-area input[type=text]{width:100%;background:rgba(124,58,237,0.06);border:1px solid var(--border);border-radius:8px;padding:9px;color:var(--text);font-size:13px;font-family:'DM Sans',sans-serif;resize:vertical;outline:none;min-height:70px}
.tool-area textarea:focus,.tool-area input[type=text]:focus{border-color:var(--purple2)}
.tool-btn{background:linear-gradient(135deg,var(--purple),var(--purple3));color:var(--white);padding:9px 20px;border-radius:8px;font-size:13px;font-weight:700;border:none;cursor:pointer;transition:all .2s;font-family:'Syne',sans-serif}
.tool-btn:hover{box-shadow:0 4px 14px rgba(124,58,237,0.4);transform:translateY(-1px)}
.tool-result{font-size:13px;color:var(--gold);margin-top:8px;display:none;word-break:break-all;text-align:left;width:100%}
.tool-stat{font-size:12px;color:var(--muted);display:flex;gap:16px;flex-wrap:wrap;justify-content:center}
.copy-btn{background:transparent;color:var(--purple2);border:1px solid var(--purple);padding:6px 14px;border-radius:6px;font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif;display:none;transition:all .2s;margin-top:6px}
.copy-btn:hover{background:rgba(124,58,237,0.15)}

/* LOGIN MODAL */
#login-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:9999;align-items:center;justify-content:center;backdrop-filter:blur(6px)}
#login-modal.open{display:flex}
.modal{background:var(--dark2);border:1px solid var(--border2);border-radius:22px;padding:38px;width:100%;max-width:400px;position:relative;margin:20px;animation:slide-up .3s ease}
@keyframes slide-up{from{transform:translateY(30px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-x{position:absolute;top:16px;right:16px;background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer;transition:color .2s}
.modal-x:hover{color:var(--white)}
.modal-title{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;color:var(--white);margin-bottom:4px}
