.modal-tab.active{background:linear-gradient(135deg,var(--purple),var(--purple3));color:var(--white)}
.modal-form{display:none}
.modal-form.active{display:block}

/* FOOTER */
footer{background:var(--dark2);border-top:1px solid var(--border);padding:56px 5% 24px;position:relative;z-index:1}
